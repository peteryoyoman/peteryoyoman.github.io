---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'books'>['data'];

const { title, author, description, pubDate, rating, coverImage, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.cover {
				display: block;
				margin: 0 auto 1em;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.title {
				text-align: center;
				line-height: 1.2;
			}
			.title h1 {
				margin: 0 0 0.25em 0;
			}
			.author {
				color: rgb(var(--gray));
				margin: 0;
			}
			.meta {
				color: rgb(var(--gray));
				margin: 0.5em 0;
			}
			.rating {
				color: #e2b23a;
				font-size: 1.2em;
			}
			.tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				justify-content: center;
				list-style: none;
				padding: 0;
			}
			.tags li {
				background: rgb(var(--gray-light));
				border-radius: 999px;
				padding: 0.2em 0.8em;
				font-size: 0.85em;
			}
			.prose {
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				{coverImage && <Image class="cover" width={320} height={480} src={coverImage} alt={title} />}
				<div class="title">
					<h1>{title}</h1>
					<p class="author">{author}</p>
					{
						rating && (
							<p class="rating">{'★'.repeat(rating)}{'☆'.repeat(5 - rating)}</p>
						)
					}
					<p class="meta"><FormattedDate date={pubDate} /></p>
					{
						tags && tags.length > 0 && (
							<ul class="tags">
								{tags.map((tag) => <li>{tag}</li>)}
							</ul>
						)
					}
					<hr />
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
