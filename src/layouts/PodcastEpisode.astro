---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'podcast'>['data'];

const { title, description, pubDate, episode, audioUrl, duration, coverImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.cover {
				display: block;
				margin: 0 auto 1em;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.title {
				text-align: center;
			}
			.title h1 {
				margin: 0.25em 0;
			}
			.meta {
				color: rgb(var(--gray));
			}
			audio {
				width: 100%;
				margin: 1em 0;
			}
			.prose {
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				{coverImage && <Image class="cover" width={320} height={320} src={coverImage} alt={title} />}
				<div class="title">
					{episode && <p class="meta">EP {episode}</p>}
					<h1>{title}</h1>
					<p class="meta">
						<FormattedDate date={pubDate} />{duration && ` · ${duration}`}
					</p>
				</div>
				<audio controls preload="none" src={audioUrl}></audio>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
