---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'races'>['data'];

const { title, description, raceDate, distance, finishTime, location, pace, heroImage } =
	Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
			.hero-image img {
				display: block;
				margin: 0 auto 1em;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				width: 100%;
			}
			.title {
				text-align: center;
			}
			.title h1 {
				margin: 0 0 0.25em 0;
			}
			.stats {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
				gap: 1em;
				margin: 1.5em 0;
				text-align: center;
			}
			.stats .box {
				background: rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1em 0.5em;
			}
			.stats .label {
				display: block;
				font-size: 0.8em;
				color: rgb(var(--gray));
			}
			.stats .value {
				display: block;
				font-size: 1.3em;
				font-weight: 700;
			}
			.prose {
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="title">
					{heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt={title} />
						</div>
					)}
					<h1>{title}</h1>
					<p><FormattedDate date={raceDate} />{location && ` · ${location}`}</p>
				</div>
				<div class="stats">
					<div class="box"><span class="label">Distance</span><span class="value">{distance}</span></div>
					<div class="box"><span class="label">Finish Time</span><span class="value">{finishTime}</span></div>
					{pace && (
						<div class="box"><span class="label">Avg Pace</span><span class="value">{pace}</span></div>
					)}
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
