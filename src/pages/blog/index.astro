---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ArchiveList from '../../components/ArchiveList.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description="Essays, notes, and things I'm thinking about." />
		<style>
			main {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ArchiveList
				eyebrow="Writing"
				title="From the blog."
				intro="Essays, notes, and things I keep turning over."
				count={`${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`}
			>
				{
					posts.map((post) => (
						<a class="arow" href={`/blog/${post.id}/`}>
							{post.data.heroImage && (
								<Image class="arow-thumb" src={post.data.heroImage} alt={post.data.title} width={140} />
							)}
							<div class="arow-body">
								<h3 class="arow-title">{post.data.title}</h3>
								<p class="arow-desc">{post.data.description}</p>
							</div>
							<span class="arow-meta">
								<FormattedDate date={post.data.pubDate} />
							</span>
						</a>
					))
				}
			</ArchiveList>
		</main>
		<Footer />
	</body>
</html>
