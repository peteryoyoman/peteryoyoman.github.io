---
import { getCollection } from 'astro:content';
import ArchiveList from '../../components/ArchiveList.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const bks = (await getCollection('books')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Books | ${SITE_TITLE}`} description="Books I've read and my notes." />
		<style>
			main {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ArchiveList
				eyebrow="Reading"
				title="Books worth the time."
				intro="What I'm reading, and the notes I take along the way."
				count={`${bks.length} ${bks.length === 1 ? 'book' : 'books'}`}
			>
				{
					bks.map((book) => (
						<a class="arow" href={`/books/${book.id}/`}>
							<div class="arow-body">
								<h3 class="arow-title">{book.data.title}</h3>
								<p class="arow-sub">{book.data.author}</p>
								<p class="arow-desc">{book.data.description}</p>
							</div>
							<span class="arow-meta">
								<FormattedDate date={book.data.pubDate} />
							</span>
						</a>
					))
				}
			</ArchiveList>
		</main>
		<Footer />
	</body>
</html>
