---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import heroImg from '../assets/hero.jpg';
import portraitImg from '../assets/portrait.jpg';

const byPub = (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf();

const allBooks = (await getCollection('books')).sort(byPub);
const allAlbums = (await getCollection('travel')).sort(byPub);
const allEpisodes = (await getCollection('podcast')).sort(byPub);
const allPosts = (await getCollection('blog')).sort(byPub);
const allRaces = (await getCollection('races')).sort(
	(a, b) => b.data.raceDate.valueOf() - a.data.raceDate.valueOf(),
);

const books = allBooks.slice(0, 4);
const albums = allAlbums.slice(0, 4);
const episodes = allEpisodes.slice(0, 3);
const posts = allPosts.slice(0, 3);
const latestRace = allRaces[0];

const stats = [
	{ n: allBooks.length, l: 'Books' },
	{ n: allRaces.length, l: 'Races' },
	{ n: allEpisodes.length, l: 'Episodes' },
];

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Still filming the only movie I get to make.`} description="Reading, travel, a podcast, and the long road to the marathon." />
		<style>
			:root {
				--mono: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
			}
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.eyebrow {
				font-family: var(--mono);
				text-transform: uppercase;
				letter-spacing: 0.22em;
				font-size: 0.74rem;
				color: var(--accent);
				margin: 0 0 1rem;
			}


			/* ---------- HERO ---------- */
			.hero {
				position: relative;
				min-height: 100svh;
				display: flex;
				align-items: flex-end;
				padding: clamp(1.25rem, 5vw, 4rem);
				padding-bottom: clamp(3rem, 8vh, 6rem);
				color: #fff;
				overflow: hidden;
			}
			.hero-bg {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				border-radius: 0;
				z-index: 0;
			}
			.hero-scrim {
				position: absolute;
				inset: 0;
				z-index: 1;
				background: linear-gradient(
					to bottom,
					rgba(30, 20, 12, 0.35) 0%,
					rgba(30, 20, 12, 0.05) 35%,
					rgba(30, 20, 12, 0.6) 100%
				);
			}
			.hero-inner {
				position: relative;
				z-index: 2;
				max-width: 1180px;
				margin: 0 auto;
				width: 100%;
			}
			.hero .kicker {
				font-family: var(--mono);
				text-transform: uppercase;
				letter-spacing: 0.28em;
				font-size: 0.78rem;
				opacity: 0.9;
				margin: 0 0 1rem;
			}
			.hero h1 {
				font-family: var(--font-fraunces);
				font-weight: 400;
				font-size: clamp(3.2rem, 12vw, 8.5rem);
				line-height: 0.95;
				letter-spacing: -0.02em;
				margin: 0;
				color: #fff;
				text-wrap: balance;
			}
			.hero .tagline {
				font-size: clamp(1.05rem, 2.5vw, 1.5rem);
				max-width: none;
				white-space: nowrap;
				margin: 1.2rem 0 0;
				opacity: 0.95;
			}

			/* ---------- SECTION SHELL ---------- */
			section.block {
				max-width: 1180px;
				margin: 0 auto;
				padding: clamp(4rem, 12vh, 9rem) clamp(1.25rem, 5vw, 4rem);
			}
			.section-title {
				font-family: var(--font-fraunces);
				font-weight: 600;
				font-size: clamp(2rem, 5vw, 3.4rem);
				line-height: 1.05;
				letter-spacing: -0.015em;
				margin: 0 0 2rem;
				color: rgb(var(--black));
				text-wrap: balance;
			}
			.viewall {
				display: inline-flex;
				align-items: center;
				gap: 0.45rem;
				margin-top: 1.6rem;
				font-family: var(--mono);
				text-transform: uppercase;
				letter-spacing: 0.12em;
				font-size: 0.8rem;
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid transparent;
				padding-bottom: 2px;
				transition: gap 0.2s ease, border-color 0.2s ease;
			}
			.viewall:hover {
				gap: 0.8rem;
				border-bottom-color: var(--accent);
			}

			/* reveal on scroll */
			.reveal {
				opacity: 0;
				transform: translateY(28px);
				transition: opacity 0.7s ease, transform 0.7s ease;
			}
			.reveal.in {
				opacity: 1;
				transform: none;
			}
			@media (prefers-reduced-motion: reduce) {
				.reveal {
					opacity: 1;
					transform: none;
					transition: none;
				}
			}

			/* ---------- ABOUT ---------- */
			.about {
				display: grid;
				grid-template-columns: 1.3fr 1fr;
				gap: clamp(2rem, 5vw, 4rem);
				align-items: center;
			}
			.about .lead {
				font-family: var(--font-fraunces);
				font-weight: 400;
				font-size: clamp(1.4rem, 3vw, 2.1rem);
				line-height: 1.35;
				color: rgb(var(--black));
				margin: 0 0 1.5rem;
			}
			.about p {
				color: rgb(var(--gray));
				margin: 0 0 1rem;
			}
			.about .portrait {
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 30px 60px rgba(120, 90, 60, 0.18);
			}
			.about .portrait img {
				width: 100%;
				aspect-ratio: 4 / 5;
				object-fit: cover;
				border-radius: 16px;
				display: block;
			}
			.stats {
				display: flex;
				gap: clamp(1.5rem, 4vw, 3rem);
				margin-top: 2rem;
				flex-wrap: wrap;
			}
			.stats .n {
				font-family: var(--font-fraunces);
				font-size: 2.4rem;
				font-weight: 600;
				color: var(--accent);
				line-height: 1;
			}
			.stats .l {
				font-size: 0.85rem;
				color: rgb(var(--gray));
				text-transform: uppercase;
				letter-spacing: 0.08em;
			}

			/* ---------- TRAVEL (full-bleed gallery) ---------- */
			.travel-head {
				max-width: 1180px;
				margin: 0 auto;
				padding: clamp(4rem, 12vh, 9rem) clamp(1.25rem, 5vw, 4rem) 2rem;
			}
			.gallery {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 6px;
			}
			.gallery a {
				display: block;
				overflow: hidden;
			}
			.gallery img {
				width: 100%;
				aspect-ratio: 3 / 4;
				object-fit: cover;
				border-radius: 0;
				display: block;
				transition: transform 0.5s ease;
			}
			.gallery a:hover img {
				transform: scale(1.04);
			}
			.travel-foot {
				max-width: 1180px;
				margin: 0 auto;
				padding: 1.5rem clamp(1.25rem, 5vw, 4rem) 0;
			}

			/* ---------- READING (note cards) ---------- */
			.note-cards {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: 1.25rem;
			}
			.note-card {
				display: block;
				text-decoration: none;
				color: rgb(var(--black));
				background: var(--surface);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				padding: 1.4rem 1.5rem;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}
			.note-card:hover {
				transform: translateY(-3px);
				box-shadow: var(--box-shadow);
			}
			.note-card .bk-title {
				font-family: var(--font-fraunces);
				font-size: 1.3rem;
				line-height: 1.2;
				margin: 0 0 0.1rem;
			}
			.note-card:hover .bk-title {
				color: var(--accent);
			}
			.note-card .bk-author {
				color: rgb(var(--gray));
				font-size: 0.85rem;
			}
			.note-card .bk-note {
				color: rgb(var(--gray-dark));
				font-size: 0.95rem;
				margin: 0.7rem 0 0;
			}

			/* ---------- BLOG (three cards) ---------- */
			.post-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 2rem;
			}
			.post a {
				display: block;
				text-decoration: none;
				color: rgb(var(--black));
			}
			.post img {
				width: 100%;
				aspect-ratio: 16 / 10;
				object-fit: cover;
				border-radius: 10px;
				box-shadow: 0 14px 30px rgba(120, 90, 60, 0.14);
				transition: transform 0.3s ease;
			}
			.post a:hover img {
				transform: translateY(-5px);
			}
			.post .pdate {
				font-family: var(--mono);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-size: 0.68rem;
				color: rgb(var(--gray));
				margin: 0.9rem 0 0.2rem;
			}
			.post h3 {
				font-family: var(--font-fraunces);
				font-size: 1.2rem;
				line-height: 1.25;
				margin: 0 0 0.3rem;
			}
			.post a:hover h3 {
				color: var(--accent);
			}
			.post .pexc {
				color: rgb(var(--gray));
				font-size: 0.9rem;
				margin: 0;
			}

			/* ---------- PODCAST + RUNNING ---------- */
			.split2 {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: clamp(2rem, 6vw, 5rem);
			}
			.ep {
				display: flex;
				gap: 1rem;
				align-items: center;
				padding: 1.1rem 0;
				border-top: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: rgb(var(--black));
			}
			.ep .play {
				width: 44px;
				height: 44px;
				border-radius: 50%;
				background: var(--accent);
				color: #fff;
				display: grid;
				place-items: center;
				flex-shrink: 0;
			}
			.ep h4 {
				font-family: var(--font-fraunces);
				font-size: 1.05rem;
				margin: 0 0 0.15rem;
			}
			.ep small {
				color: rgb(var(--gray));
			}
			.ep:hover h4 {
				color: var(--accent);
			}
			.race {
				background: var(--surface);
				border: 1px solid rgb(var(--gray-light));
				border-radius: 16px;
				padding: 1.8rem;
			}
			.race .big {
				font-family: var(--font-fraunces);
				font-size: 3.2rem;
				font-weight: 600;
				color: var(--accent);
				line-height: 1;
				margin: 0.5rem 0;
			}
			.race .rrow {
				display: flex;
				justify-content: space-between;
				padding: 0.6rem 0;
				border-top: 1px solid rgb(var(--gray-light));
				font-variant-numeric: tabular-nums;
			}
			.race .rrow span:first-child {
				color: rgb(var(--gray));
			}

			/* ---------- CONTACT ---------- */
			.contact {
				background: rgb(var(--black));
				color: var(--bg);
				text-align: center;
			}
			.contact-inner {
				max-width: 720px;
				margin: 0 auto;
				padding: clamp(4rem, 14vh, 9rem) clamp(1.25rem, 5vw, 4rem);
			}
			.contact h2 {
				font-family: var(--font-fraunces);
				font-weight: 400;
				font-size: clamp(2.4rem, 7vw, 5rem);
				margin: 0.5rem 0 1.5rem;
				line-height: 1;
				color: var(--bg);
			}
			.contact a.mail {
				font-family: var(--font-fraunces);
				font-size: clamp(1.2rem, 3vw, 1.8rem);
				color: #fff;
				text-decoration: none;
				border-bottom: 2px solid var(--accent);
				padding-bottom: 0.15em;
			}
			.contact .socials {
				display: flex;
				gap: 1.5rem;
				justify-content: center;
				margin-top: 2.5rem;
				color: rgba(255, 255, 255, 0.7);
				font-size: 0.9rem;
			}
			.contact .socials a {
				color: inherit;
				text-decoration: none;
			}
			.contact .socials a:hover {
				color: #fff;
			}

			.mini-foot {
				background: var(--surface);
				border-top: 1px solid rgb(var(--gray-light));
				color: rgb(var(--gray));
				font-size: 0.85rem;
				text-align: center;
				padding: 1.5rem 1rem;
			}

			@media (max-width: 820px) {
				.about {
					grid-template-columns: 1fr;
				}
				.about .portrait {
					order: -1;
				}
				.split2 {
					grid-template-columns: 1fr;
				}
			}
			@media (max-width: 720px) {
				.hero .tagline {
					white-space: normal;
				}
				.gallery {
					grid-template-columns: repeat(2, 1fr);
				}
				.note-cards {
					grid-template-columns: 1fr;
				}
				.post-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header overHero />

		<main>
			<header class="hero" id="top">
				<Image class="hero-bg" src={heroImg} alt="" fetchpriority="high" />
				<div class="hero-scrim"></div>
				<div class="hero-inner">
					<p class="kicker">Reader · Runner · Traveler</p>
					<h1>Peter Tsai</h1>
					<p class="tagline">Still filming the only movie I get to make.</p>
				</div>
			</header>

			<section class="block about" id="about">
				<div class="reveal">
					<p class="eyebrow">About</p>
					<p class="lead">
						I'm Peter — a runner, reader, and traveler based in Taipei, keeping the four things I
						care about most in one place.
					</p>
					<p>
						This is my corner of the web: what I'm reading and the notes I take, the places I travel
						to and the photos I bring home, a podcast where I think out loud, and every race on the
						way to a faster marathon.
					</p>
					<div class="stats">
						{stats.map((s) => (
							<div>
								<div class="n">{s.n}</div>
								<div class="l">{s.l}</div>
							</div>
						))}
					</div>
				</div>
				<div class="portrait reveal">
					<Image src={portraitImg} alt="Portrait of Peter" width={640} height={800} />
				</div>
			</section>

			{albums.length > 0 && (
				<>
					<div class="travel-head reveal" id="travel">
						<p class="eyebrow">Travel</p>
						<h2 class="section-title">Notes from the road.</h2>
					</div>
					<div class="gallery reveal">
						{albums.map((album) => (
							<a href={`/travel/${album.id}/`}>
								<Image src={album.data.coverImage} alt={album.data.title} width={480} height={640} />
							</a>
						))}
					</div>
					<div class="travel-foot reveal">
						<a class="viewall" href="/travel">All travel stories →</a>
					</div>
				</>
			)}

			{books.length > 0 && (
				<section class="block" id="reading">
					<div class="reveal">
						<p class="eyebrow">Reading</p>
						<h2 class="section-title">Books worth the time.</h2>
					</div>
					<div class="note-cards reveal">
						{books.map((book) => (
							<a class="note-card" href={`/books/${book.id}/`}>
								<h3 class="bk-title">{book.data.title}</h3>
								<span class="bk-author">{book.data.author}</span>
								<p class="bk-note">{book.data.description}</p>
							</a>
						))}
					</div>
					<a class="viewall reveal" href="/books">All reading notes →</a>
				</section>
			)}

			{posts.length > 0 && (
				<section class="block" id="blog">
					<div class="reveal">
						<p class="eyebrow">Writing</p>
						<h2 class="section-title">From the blog.</h2>
					</div>
					<div class="post-grid reveal">
						{posts.map((post) => (
							<article class="post">
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image src={post.data.heroImage} alt={post.data.title} width={480} height={300} />
									)}
									<p class="pdate">
										{post.data.pubDate.toLocaleDateString('en-US', {
											month: 'short',
											year: 'numeric',
										})}
									</p>
									<h3>{post.data.title}</h3>
									<p class="pexc">{post.data.description}</p>
								</a>
							</article>
						))}
					</div>
					<a class="viewall reveal" href="/blog">All posts →</a>
				</section>
			)}

			<section class="block split2">
				{episodes.length > 0 && (
					<div class="reveal" id="podcast">
						<p class="eyebrow">Podcast</p>
						<h2 class="section-title">Thinking out loud.</h2>
						{episodes.map((ep) => (
							<a class="ep" href={`/podcast/${ep.id}/`}>
								<div class="play">▶</div>
								<div>
									<h4>{ep.data.episode ? `EP ${ep.data.episode} · ` : ''}{ep.data.title}</h4>
									<small>{ep.data.duration ? `${ep.data.duration} · ` : ''}{ep.data.pubDate.getFullYear()}</small>
								</div>
							</a>
						))}
						<a class="viewall" href="/podcast">All episodes →</a>
					</div>
				)}

				{latestRace && (
					<div class="reveal" id="running">
						<p class="eyebrow">Running</p>
						<h2 class="section-title">Latest race.</h2>
						<div class="race">
							<div class="eyebrow" style="margin-bottom: 0">{latestRace.data.title}</div>
							<div class="big">{latestRace.data.finishTime}</div>
							<div class="rrow"><span>Distance</span><span>{latestRace.data.distance}</span></div>
							{latestRace.data.pace && (
								<div class="rrow"><span>Avg pace</span><span>{latestRace.data.pace}</span></div>
							)}
							{latestRace.data.location && (
								<div class="rrow"><span>Where</span><span>{latestRace.data.location}</span></div>
							)}
						</div>
						<a class="viewall" href="/races">Full running log →</a>
					</div>
				)}
			</section>

			<section class="contact" id="contact">
				<div class="contact-inner reveal">
					<p class="eyebrow" style="color: var(--accent)">Contact</p>
					<h2>Say hello.</h2>
					<a class="mail" href="mailto:peter1102peter1102@gmail.com">peter1102peter1102@gmail.com</a>
				</div>
			</section>
		</main>

		<footer class="mini-foot">© {new Date().getFullYear()} Peter Tsai</footer>

		<script>
			// scroll reveal
			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							e.target.classList.add('in');
							io.unobserve(e.target);
						}
					});
				},
				{ threshold: 0.15 },
			);
			document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
		</script>
	</body>
</html>
