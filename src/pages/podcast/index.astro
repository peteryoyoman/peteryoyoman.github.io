---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ArchiveList from '../../components/ArchiveList.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const eps = (await getCollection('podcast')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Podcast | ${SITE_TITLE}`} description="Episodes from my podcast." />
		<style>
			main {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ArchiveList
				eyebrow="Podcast"
				title="Thinking out loud."
				intro="Essays for the ears — reading, running, and finishing what I start."
				count={`${eps.length} ${eps.length === 1 ? 'episode' : 'episodes'}`}
			>
				{
					eps.map((ep) => (
						<a class="arow" href={`/podcast/${ep.id}/`}>
							{ep.data.coverImage && (
								<Image class="arow-thumb" src={ep.data.coverImage} alt={ep.data.title} width={140} />
							)}
							<div class="arow-body">
								<h3 class="arow-title">
									{ep.data.episode ? `EP ${ep.data.episode} · ` : ''}
									{ep.data.title}
								</h3>
								<p class="arow-desc">{ep.data.description}</p>
							</div>
							<span class="arow-meta">
								<FormattedDate date={ep.data.pubDate} />
								{ep.data.duration ? ` · ${ep.data.duration}` : ''}
							</span>
						</a>
					))
				}
			</ArchiveList>
		</main>
		<Footer />
	</body>
</html>
