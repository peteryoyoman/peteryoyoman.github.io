---
import { getCollection } from 'astro:content';
import ArchiveList from '../../components/ArchiveList.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const races = (await getCollection('races')).sort(
	(a, b) => b.data.raceDate.valueOf() - a.data.raceDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Running | ${SITE_TITLE}`} description="My road-race and marathon logs." />
		<style>
			main {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ArchiveList
				eyebrow="Running"
				title="The long road."
				intro="Every race on the way to a faster marathon."
				count={`${races.length} ${races.length === 1 ? 'race' : 'races'}`}
			>
				{
					races.map((race) => (
						<a class="arow" href={`/races/${race.id}/`}>
							<div class="arow-body">
								<h3 class="arow-title">{race.data.title}</h3>
								<p class="arow-sub">
									<FormattedDate date={race.data.raceDate} />
									{race.data.location ? ` · ${race.data.location}` : ''}
								</p>
							</div>
							<span class="arow-stat">
								<span class="t">{race.data.finishTime}</span>
								<span class="d">{race.data.distance}</span>
							</span>
						</a>
					))
				}
			</ArchiveList>
		</main>
		<Footer />
	</body>
</html>
