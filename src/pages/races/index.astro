---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const races = (await getCollection('races')).sort(
	(a, b) => b.data.raceDate.valueOf() - a.data.raceDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Running | ${SITE_TITLE}`} description="My road-race and marathon logs." />
		<style>
			main { width: 800px; max-width: calc(100% - 2em); margin: auto; }
			table { width: 100%; border-collapse: collapse; }
			th, td { text-align: left; padding: 0.75em 0.5em; border-bottom: 1px solid rgb(var(--gray-light)); }
			th { color: rgb(var(--gray)); font-size: 0.85em; text-transform: uppercase; letter-spacing: 0.05em; }
			td a { color: inherit; text-decoration: none; font-weight: 600; }
			td a:hover { color: rgb(var(--accent)); }
			.num { font-variant-numeric: tabular-nums; }
			@media (max-width: 640px) {
				th:nth-child(4), td:nth-child(4) { display: none; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Running Log</h1>
			<table>
				<thead>
					<tr>
						<th>Race</th>
						<th>Distance</th>
						<th class="num">Finish</th>
						<th>Date</th>
					</tr>
				</thead>
				<tbody>
					{
						races.map((race) => (
							<tr>
								<td><a href={`/races/${race.id}/`}>{race.data.title}</a></td>
								<td>{race.data.distance}</td>
								<td class="num">{race.data.finishTime}</td>
								<td><FormattedDate date={race.data.raceDate} /></td>
							</tr>
						))
					}
				</tbody>
			</table>
		</main>
		<Footer />
	</body>
</html>
