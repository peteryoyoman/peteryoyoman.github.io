---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const albums = (await getCollection('travel')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Travel | ${SITE_TITLE}`} description="Notes and photos from the road." />
		<style>
			main { width: 960px; max-width: calc(100% - 2em); margin: auto; }
			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}
			.card a { text-decoration: none; color: inherit; display: block; }
			.card img {
				width: 100%;
				aspect-ratio: 4 / 3;
				object-fit: cover;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				transition: 0.2s ease;
			}
			.card a:hover img { transform: translateY(-4px); }
			.card h3 { margin: 0.6em 0 0.1em; line-height: 1.2; }
			.card .meta { margin: 0; color: rgb(var(--gray)); font-size: 0.9em; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Travel</h1>
			<div class="grid">
				{
					albums.map((album) => (
						<div class="card">
							<a href={`/travel/${album.id}/`}>
								<Image width={560} height={420} src={album.data.coverImage} alt={album.data.title} />
								<h3>{album.data.title}</h3>
								<p class="meta">
									<FormattedDate date={album.data.pubDate} />{album.data.location && ` · ${album.data.location}`}
								</p>
							</a>
						</div>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
