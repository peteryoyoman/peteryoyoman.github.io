---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ArchiveList from '../../components/ArchiveList.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const trips = (await getCollection('travel')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Travel | ${SITE_TITLE}`} description="Notes and photos from the road." />
		<style>
			main {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<ArchiveList
				eyebrow="Travel"
				title="Notes from the road."
				intro="Places I've wandered, and the photos I brought home."
				count={`${trips.length} ${trips.length === 1 ? 'trip' : 'trips'}`}
			>
				{
					trips.map((trip) => (
						<a class="arow" href={`/travel/${trip.id}/`}>
							<Image class="arow-thumb" src={trip.data.coverImage} alt={trip.data.title} width={140} />
							<div class="arow-body">
								<h3 class="arow-title">{trip.data.title}</h3>
								<p class="arow-desc">{trip.data.description}</p>
							</div>
							<span class="arow-meta">
								<FormattedDate date={trip.data.pubDate} />
								{trip.data.location ? ` · ${trip.data.location}` : ''}
							</span>
						</a>
					))
				}
			</ArchiveList>
		</main>
		<Footer />
	</body>
</html>
